class Solution:
    def maxProduct(self, nums: List[int]) -> int:
        curMax = nums[0]
        curMin = nums[0]
        ans = nums[0]

        for i in range(1, len(nums)):
            n = nums[i]

            if n < 0:
                curMax, curMin = curMin, curMax

            curMax = max(n, curMax * n)
            curMin = min(n, curMin * n)

            ans = max(ans, curMax)

        return ans
